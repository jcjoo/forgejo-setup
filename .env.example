# Copie para .env e ajuste. Em produção, troque FORGEJO_ROOT_URL pelo
# domínio/IP real do servidor (ex.: https://git.pso.com.br/).
FORGEJO_HTTP_PORT=3300
FORGEJO_SSH_PORT=2222
FORGEJO_ROOT_URL=http://localhost:3300/

POSTGRES_USER=forgejo
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=forgejo

# Runner de CI — com o Forgejo já no ar (admin criado), gere com:
#   docker compose exec -u 1000 forgejo forgejo actions generate-runner-token
# (ou rode ./setup-runner.sh, que faz isso e grava aqui). Sem isso, o runner
# não sobe na primeira vez (veja runner-entrypoint.sh).
RUNNER_REGISTRATION_TOKEN=
