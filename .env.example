# Variáveis da stack (no Portainer, preencha em "Environment variables").

# --- Forgejo (obrigatórias) ---
# URL pública. Atrás do nginx com TLS, use https:// e o domínio sem porta.
FORGEJO_ROOT_URL=https://git.pso.com.br/
FORGEJO_DOMAIN=git.pso.com.br

# Portas publicadas no host (nginx aponta pro HTTP).
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222

# --- Banco (senha obrigatória) ---
POSTGRES_USER=forgejo
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=forgejo

# --- Runner de CI ---
# Deixe VAZIO no 1º deploy. Depois do install, pegue o token em
# Admin > Actions > Runners > "Create new Runner", cole aqui e faça redeploy.
RUNNER_REGISTRATION_TOKEN=
RUNNER_NAME=pso-runner

# URL interna que o runner usa pra falar com o Forgejo (rede do compose).
# NÃO use o domínio público aqui — sair pro nginx/HTTPS quebra o CI. O
# padrão já serve; só mude se renomear o serviço "forgejo".
RUNNER_INSTANCE_URL=http://forgejo:3000/

# Imagem de JOB (o que roda dentro do runs-on:). Em Docker 29+ ela precisa
# ter o /var/run real; a do ghcr já tem. Vem de registry (o Portainer não
# builda). Troque se publicar outra imagem de job.
CI_JOB_IMAGE=ghcr.io/jcjoo/pso-forgejo-runner:latest
